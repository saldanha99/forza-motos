# Copie para .env.local e preencha os valores

# PostgreSQL próprio na VPS (container "db" na rede docker "forza").
# Conexão direta, sem pooler — não use mais Neon.
# Ex.: postgresql://forza_user:SENHA@db:5432/forzamotos?sslmode=disable
DATABASE_URL=postgresql://usuario:senha@db:5432/forzamotos?sslmode=disable

NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=https://seudominio.com.br

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MERCADOPAGO_ACCESS_TOKEN=
# Assinatura secreta do webhook (MP → Suas integrações → Webhooks → Assinatura secreta)
# Sem isso o webhook aceita qualquer requisição (apenas re-valida o pagamento na API).
MERCADOPAGO_WEBHOOK_SECRET=

BLOB_READ_WRITE_TOKEN=

OLIST_CLIENT_ID=
OLIST_CLIENT_SECRET=
OLIST_TOKEN=
# Token opcional para proteger o webhook de entrada do Olist/Tiny.
# Se setado, cadastre a URL do webhook como .../api/olist/webhook?secret=<valor>
OLIST_WEBHOOK_SECRET=

CORREIOS_USUARIO=
CORREIOS_SENHA=

# ============================================================
# Melhor Envio — cotação de frete (PAC, SEDEX, Jadlog, JeT, etc)
# ============================================================
# 1. Cadastro gratuito: https://melhorenvio.com.br
# 2. Token: Menu → Configurações → Tokens → Gerar Token de API
# 3. Em PRODUÇÃO use https://www.melhorenvio.com.br/api/v2
#    Em DESENVOLVIMENTO use https://sandbox.melhorenvio.com.br/api/v2 (recomendado para testes)
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_URL=https://sandbox.melhorenvio.com.br/api/v2
MELHOR_ENVIO_CEP_ORIGEM=
# User-Agent deve incluir um email de contato — obrigatório pela documentação
MELHOR_ENVIO_USER_AGENT=Forza Motos contato@forzamotos.com.br

WHATSAPP_NUMBER=5519974049445
NEXT_PUBLIC_WHATSAPP=5519974049445

# ============================================================
# Evolution API (WhatsApp) + Assessoria de estoque
# ============================================================
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=forza-motos
# JID do grupo de assessoria (alerta de conflito de estoque nos agendamentos).
# Formato de grupo: 120363XXXXXXXXXXXX@g.us — NÃO é telefone.
# Também pode ser definido no banco (Setting key=grupo_assessoria_jid).
GRUPO_ASSESSORIA_JID=

# ============================================================
# SEO Toolkit
# ============================================================

# Site base URL (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://forzamotos.com.br

# Google Site Verification for Search Console
GOOGLE_SITE_VERIFICATION=

# Cron (gere com: openssl rand -hex 32)
CRON_SECRET=

# IA — Glossário (escolha 1 ou os 2 providers)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Indexing API (opcional, requer Service Account)
# Cole o JSON completo do service account
GOOGLE_INDEXING_CREDENTIALS=

# IndexNow (Bing/Yandex) — gere com: openssl rand -hex 32
# Lembre de criar public/<INDEXNOW_KEY>.txt com o conteúdo igual à chave
INDEXNOW_KEY=

