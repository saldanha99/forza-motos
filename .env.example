OLIST_TOKEN=

CORREIOS_USUARIO=
CORREIOS_SENHA=

WHATSAPP_NUMBER=5519974049445
NEXT_PUBLIC_WHATSAPP=5519974049445

# ============================================================
# SEO Toolkit
# ============================================================

# Site base URL (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://forza-motos-app.vercel.app

# Cron (gere com: openssl rand -hex 32)
CRON_SECRET=

# IA — Glossário (escolha 1 ou os 2 providers)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Indexing API (opcional, requer Service Account)
# Cole o JSON completo do service account
GOOGLE_INDEXING_CREDENTIALS=

# IndexNow (Bing/Yandex) — gere com: openssl rand -hex 32
# Lembre de criar public/<INDEXNOW_KEY>.txt com o conteúdo igual à chave
INDEXNOW_KEY=

